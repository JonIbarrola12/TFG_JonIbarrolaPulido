### .gitignore para repositorio .NET + Angular

# Visual Studio / .NET
bin/
obj/
*.user
*.suo
*.userosscache
*.sln.docstates
.vs/
TestResults/
nupkg/
*.nupkg
*.snk

# Rider
.idea/

# Logs
*.log

# OS
.DS_Store
Thumbs.db

# Secret / local settings
**/appsettings.Development.json

# Node / Frontend
Frontend/SportsHome/node_modules/
Frontend/SportsHome/dist/
Frontend/SportsHome/.angular/
Frontend/SportsHome/.vscode/

# Database backups
Database/*.bak
Database/*.mdf
Database/*.ldf

# Docs
Docs/**/*.tmp

# Ignore JetBrains ReSharper cache
*.ReSharper*/

# Ignore deployment artifacts
*.publish/

# Ignore package lock files generated by local build tools (if any)
package-lock.json

# End of file
